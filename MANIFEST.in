# Include the framework source and metadata
include LICENSE
include README.md
include CHANGELOG.md
include pyproject.toml
include AGENTS.md
include CLAUDE.md
recursive-include easycord *.py py.typed
recursive-include docs *.md
recursive-include examples *.py
recursive-include context *.md

# Exclude everything that is not part of the published library
exclude .gitignore
prune tests
prune .claude
prune .pytest_cache
global-exclude __pycache__
global-exclude *.py[cod]
global-exclude *.pyo
global-exclude .DS_Store
global-exclude Thumbs.db
